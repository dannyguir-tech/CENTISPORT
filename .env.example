# Postgres connection
# Local example: postgres://postgres:postgres@localhost:5432/centisport
DATABASE_URL=

# Telegram bot alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Comma-separated Polymarket event URLs for MVP scanning
EVENT_URLS=

# Scanner settings
SCAN_INTERVAL_SECONDS=300
MIN_DATA_QUALITY=0.90
ALERT_BETS_ONLY=true
ALERT_LEANS=false
DUPLICATE_ALERT_MINUTES=10

# Local Sports Money userscript path
USER_SCRIPT_PATH=vendor/pm-sports-dashboard.user.js

# Browser settings
HEADLESS=true
PAGE_TIMEOUT_MS=120000
EXPORT_TIMEOUT_MS=120000
